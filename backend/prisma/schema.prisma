generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite does not support enums, so we will use Strings in the models
// but keep these for reference or use them in application logic.
// ADMIN, FIELD_AGENT
// Planted, Growing, Ready, Harvested

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  password       String
  role           String        @default("FIELD_AGENT")
  assignedFields Field[]       @relation("AssignedAgent")
  createdFields  Field[]       @relation("CreatedBy")
  updates        FieldUpdate[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Field {
  id              String        @id @default(uuid())
  name            String
  crop_type       String
  planting_date   DateTime
  current_stage   String         @default("Planted")
  assigned_agent_id String?
  assigned_agent  User?         @relation("AssignedAgent", fields: [assigned_agent_id], references: [id])
  created_by_id   String
  created_by      User          @relation("CreatedBy", fields: [created_by_id], references: [id])
  updates         FieldUpdate[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model FieldUpdate {
  id             String   @id @default(uuid())
  field_id       String
  field          Field    @relation(fields: [field_id], references: [id], onDelete: Cascade)
  updated_by_id  String
  updated_by     User     @relation(fields: [updated_by_id], references: [id])
  stage          String
  notes          String?
  createdAt      DateTime @default(now())
}
